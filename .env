POSTGRES_DB=ecosystem_db
POSTGRES_USER=ecosystem_user
POSTGRES_PASSWORD=ecosystem_password
POSTGRES_PORT=5432
REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg2://ecosystem_user:ecosystem_password@postgres:5432/ecosystem_db
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

AUTH_SERVICE_URL=http://auth_service:8001
AUTHORIZATION_SERVICE_URL=http://authorization_service:8002
USER_SERVICE_URL=http://user_service:8003
SERVICE_REGISTRY_URL=http://service_registry:8004
API_GATEWAY_URL=http://api_gateway:8000
DEMO_SERVICE_URL=http://demo_microservice:8005

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
